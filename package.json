{
  "name": "swift-crm",
  "version": "0.0.0",
  "private": true,
  "description": "Modern CRM platform with Kanban board, real-time sync, and analytics",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@swift/web",
    "dev:api": "turbo run dev --filter=@swift/api",
    "dev:mobile": "turbo run dev --filter=@swift/mobile",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "e2e": "turbo run e2e --filter=@swift/web",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "turbo run db:generate --filter=@swift/db",
    "db:migrate": "turbo run db:migrate --filter=@swift/db",
    "db:migrate:deploy": "turbo run db:migrate:deploy --filter=@swift/db",
    "db:seed": "turbo run db:seed --filter=@swift/db",
    "db:studio": "turbo run db:studio --filter=@swift/db",
    "check": "bun run lint && bun run typecheck && bun run test",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.4.0",
    "@commitlint/config-conventional": "^19.4.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.1"
  },
  "packageManager": "bun@1.1.0",
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json,yml,yaml}": [
      "prettier --write"
    ]
  }
}
