#  Database (PostgreSQL)
POSTGRES_USER=swift
POSTGRES_PASSWORD=swift_dev_password
POSTGRES_DB=swift
DATABASE_URL=postgresql://swift:swift_dev_password@localhost:5432/swift?schema=public

#  Redis (cache, pub/sub, sessions)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

#  S3-compatible storage (MinIO в dev)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=swift-attachments
S3_REGION=us-east-1

#  Auth / JWT
# Сгенерируй: openssl rand -base64 64
JWT_ACCESS_SECRET=replace_me_with_long_random_string_min_32_chars
JWT_REFRESH_SECRET=replace_me_with_another_long_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

#  API
API_PORT=3001
API_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

#  Web (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

#  Email (Mailhog в dev, Resend в prod)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Swift CRM <noreply@swift.local>

#  Monitoring (опционально в dev)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

#  Feature flags
NODE_ENV=development
LOG_LEVEL=debug
